# Makevars.win for xad-r package (Windows)
# See src/Makevars for rationale (headers shipped under inst/include/XAD/).

CXX_STD = CXX17

PKG_CXXFLAGS = \
  -I../inst/include \
  -DXAD_NO_STRONG_INLINE

PKG_LIBS =

SOURCES = RcppExports.cpp xad_bindings.cpp xad_tape.cpp

OBJECTS = $(SOURCES:.cpp=.o)
